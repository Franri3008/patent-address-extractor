{
  "_comment": "Copy this file to config.json and fill in your values.",
  "run_mode": "batch",
  "individual": {
    "patent_id": "WO2025086418",
    "keep_temp_files": true,
    "save_thumbnails": true
  },
  "batch": {
    "year": 2025,
    "month": 1,
    "limit": null
  },
  "bigquery": {
    "project_id": "your-gcp-project",
    "use_adc": true,
    "credentials_path": null
  },
  "pdf": {
    "dpi": 150,
    "max_pages": 3,
    "thumbnail_dpi": 72
  },
  "ocr": {
    "model": "dots_ocr",
    "device": "auto",
    "_comment_ocr": "For vLLM-served PaddleOCR-VL, set model to 'paddle_ocr_vllm' and configure:",
    "vllm_base_url": "http://localhost:8000/v1",
    "vllm_model": "PaddlePaddle/PaddleOCR-VL"
  },
  "llm": {
    "provider": "ollama",
    "model": "gemma3:27b",
    "api_key_env": null,
    "temperature": 0.1,
    "max_retries": 2,
    "post_validation": {
      "_comment": "Deterministic checks after LLM extraction (country codes, missing entities, section consistency).",
      "enabled": false
    }
  },
  "column_detection": {
    "_comment": "Detect and split two-column WIPO first pages before OCR. Only applies to page 1.",
    "enabled": false,
    "confidence_threshold": 0.7
  },
  "verification": {
    "_comment": "Vision LLM fallback: re-extracts via image when post-validation flags issues.",
    "enabled": false,
    "vision_llm": {
      "provider": "ollama",
      "model": "gemma4:e2b",
      "temperature": 0.0
    }
  },
  "workers": {
    "pdf_concurrency": 8,
    "ocr_workers": 1,
    "llm_concurrency": 1,
    "queue_max_size": 32
  },
  "output": {
    "dir": "output/",
    "filename_template": "patents_{yyyy}_{mm}"
  }
}
